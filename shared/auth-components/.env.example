# Microsoft Entra ID Configuration
# Copy this file to .env and fill in your values

# Required: Your Entra ID application (client) ID
ENTRA_CLIENT_ID=your-client-id-here

# Required: Your Entra ID tenant (directory) ID
ENTRA_TENANT_ID=your-tenant-id-here

# Optional: Authority URL (defaults to https://login.microsoftonline.com/{ENTRA_TENANT_ID})
# ENTRA_AUTHORITY=https://login.microsoftonline.com/your-tenant-id-here

# Optional: Scopes to request (defaults to https://graph.microsoft.com/.default)
# ENTRA_SCOPES=https://graph.microsoft.com/.default,User.Read

# Optional: Path to token cache file (defaults to .auth_cache)
# TOKEN_CACHE_PATH=.auth_cache

# Note: The application must be configured for device code flow in Entra ID.
# Required permissions for OneDrive integration:
# - Files.ReadWrite.All (to read/write OneDrive files)
# - User.Read (to get user profile information)